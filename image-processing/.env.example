# SEAS Image Processing Service - Environment Configuration

# Service settings
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:5173"]

# Model paths
DLIB_FACE_PREDICTOR_PATH=models/shape_predictor_68_face_landmarks.dat
DLIB_FACE_RECOGNITION_MODEL_PATH=models/dlib_face_recognition_resnet_model_v1.dat
ANTI_SPOOF_MODEL_PATH=models/anti_spoof_model.h5

# Face detection settings
FACE_DETECTION_UPSAMPLE=1
MIN_FACE_SIZE=80

# Face matching thresholds
FACE_MATCH_THRESHOLD=0.6
FACE_MATCH_STRICT_THRESHOLD=0.7

# Liveness detection thresholds
LIVENESS_THRESHOLD=0.5
SPOOF_THRESHOLD=0.5

# Eye Aspect Ratio (EAR) settings for blink detection
EAR_THRESHOLD=0.25
EAR_CONSEC_FRAMES=2

# Head pose thresholds (degrees)
HEAD_POSE_YAW_THRESHOLD=30.0
HEAD_POSE_PITCH_THRESHOLD=30.0
HEAD_POSE_ROLL_THRESHOLD=25.0

# Image processing settings
MAX_IMAGE_SIZE=10485760
TARGET_FACE_SIZE=160

# Backend service URL (NestJS)
BACKEND_URL=http://localhost:3000

# Storage settings
FACE_TEMPLATES_DIR=data/face_templates
