# ============================================
# SEAS - Environment Configuration
# Copy this file to .env and update values
# ============================================

# ---- Database ----
POSTGRES_USER=seas_user
POSTGRES_PASSWORD=seas_password
POSTGRES_DB=seas_db

# ---- Backend ----
NODE_ENV=production
PORT=3000
JWT_SECRET=change-this-to-a-secure-secret-key-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Image Processing ----
FACE_MATCH_THRESHOLD=0.6
LIVENESS_THRESHOLD=0.5
SPOOF_THRESHOLD=0.5
EAR_THRESHOLD=0.25

# ---- Frontend (Build-time) ----
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
VITE_IMAGE_PROCESSING_URL=http://localhost:8000
